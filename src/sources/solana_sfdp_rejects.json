{
  "name": "solana::sfdp_rejects",
  "url": "https://api.solana.org/api/community/v1/sfdp_participants",
  "contact_into": {
    "discord": "https://solana.com/discord",
    "website": "https://solana.com"
  },
  "handler": "Json",
  "filters": [
    "?(@.state == 'Rejected')"
  ],
  "record_path": "$..*",
  "pubkey_path": "$.mainnetBetaPubkey",
  "reason_path": "$.state"
}
