{
  "name": "sandwiched_me",
  "url": "https://nextgen.mev-hub.snowgenesis.com/api/pub/validator_stats",
  "fetch_headers": {
    "X-API-KEY": "${SANDWICHED_ME_API_KEY}"
  },
  "contact_info": {
    "website": "https://sandwiched.me",
    "telegram": "https://t.me/ghostlogsxyz"
  },
  "handler": "Json",
  "filters": [
    "$.stats[?(@.period.Days == 30 && @.sandwichRate > 5)]"
  ],
  "record_path": "$.data.validators[*]",
  "pubkey_path": "$.validatorVoteAccount",
  "reason_template": "30-day sandwich rate: {$.stats[?(@.period.Days == 30)].sandwichRate:.2}%"
}
