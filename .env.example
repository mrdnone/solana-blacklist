# Path to the SQLite database file
BLACKLIST_DB_PATH=./blacklist.db

# Solana RPC endpoint used to fetch validator vote accounts
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# How often (in seconds) to refresh the blacklist cache from external sources
BLACKLIST_REFRESH_SECS=300

# Set to "false" or "0" to include inactive/delinquent validators in results
BLACKLIST_FILTER_INACTIVE=true

# Secret key for admin endpoints (X-Admin-Key header).
# Leave unset to disable admin endpoints entirely (they return 503).
ADMIN_KEY=change-me-to-a-strong-secret
