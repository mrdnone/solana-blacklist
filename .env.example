# Copy this to .env and fill in the values before running docker compose up.
# BLACKLIST_DB_PATH is set by docker-compose.yml — do not override here.

# Solana RPC endpoint used to fetch and validate active validators.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# How often (seconds) to re-fetch all blacklist sources. Default: 300.
BLACKLIST_REFRESH_SECS=300

# Set to "false" or "0" to include inactive/delinquent validators in results.
BLACKLIST_FILTER_INACTIVE=true

# API key for sandwiched.me validator stats source.
SANDWICHED_ME_API_KEY=

# Admin API key — required to use /api/admin/* endpoints.
# Leave unset or empty to disable admin endpoints entirely (returns 503).
ADMIN_KEY=
